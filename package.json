{
  "name": "tamdoku",
  "version": "0.1.8",
  "private": true,
  "type": "module",
  "description": "Tamdoku — le puzzle quotidien du tramway de Montpellier",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "fetch:osm": "tsx pipeline/fetch-osm.ts",
    "fetch:gtfs": "tsx pipeline/fetch-gtfs.ts",
    "fetch:communes": "tsx pipeline/fetch-communes.ts",
    "build:network": "tsx pipeline/build-network.ts",
    "build:data": "npm run fetch:osm && npm run fetch:gtfs && npm run fetch:communes && npm run build:network",
    "stats": "tsx cli/stats.ts",
    "gen": "tsx cli/gen.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.1.0"
  }
}
