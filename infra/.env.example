# Copier en .env sur le serveur (jamais committé — cf .gitignore).
# INSTANCE_SECRET : générer avec  openssl rand -hex 32

INSTANCE_NAME=tamdoku
INSTANCE_SECRET=__openssl_rand_hex_32__

# Ports hôte (localhost) — libres sur cookie-server : 3240/3241/6794
PORT=3240
SITE_PROXY_PORT=3241
DASHBOARD_PORT=6794

# Origine « cloud » = API + websocket Convex. Exposée sur t-convex.my-monkey.fr
# pour le dashboard réactif (Convex useQuery, temps réel). Le deploy CLI passe
# par CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3240 (host-local), pas par ceci.
CONVEX_CLOUD_ORIGIN=https://t-convex.my-monkey.fr

# Origine « site » = HTTP actions exposées publiquement (POST /submit, GET /popularity).
CONVEX_SITE_ORIGIN=https://t-api.my-monkey.fr

RUST_LOG=info
